{
  "buildCommand": "",
  "outputDirectory": "",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/comments", "destination": "/api/comments" },
    { "source": "/api/admin/:path*", "destination": "/api/admin" },
    { "source": "/api/ads", "destination": "/api/ads" },
    { "source": "/api/migrate", "destination": "/api/migrate" },
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
